#define _CRT_SECURE_NO_WARNINGS
#include<stdio.h>
int main()
{
	puts("这是一个时间计算器\n");
	int hour1 = 0, min1 = 0;
	int hour2 = 0, min2 = 0;
	int time1 = 0, time2 = 0, TIME = 0;
	int hour3 = 0, min3 = 0;
	printf("输入两次时间：\n");

	puts("输入第一次时间：");
	scanf("%d %d", &hour1, &min1);

	puts("输入第二次时间：");
	scanf("%d %d", &hour2, &min2);

	// scanf("输入小时：%d/n输入分钟：%d\n", &hour1, &min1);
	 //scanf("输入小时：%d/n输入分钟：%d", &hour2, & min2);
	time1 = hour1 * 60 + min1;
	time2 = hour2 * 60 + min2;
	TIME = time1 - time2;
	if (TIME < 0)
		TIME = TIME * (-1);

	printf("两个时间差是：%d小时%d分钟", TIME / 60, TIME % 60);
	return 0;
}
