//输入一个长度不大于100的数组，比较大小

#define _CRT_SECURE_NO_WARNINGS
#include<stdio.h>
int main()
{
	int n = 0, i = 0;
	int arr[100] = {0};
	printf("输入一个不大于100的数，得到一个长度为n的数组：");
	scanf("%d", &n);

	if (n > 100 || n <= 0)
	{
		puts("请输入不大于100的数字!");
		return 0;
	}
	while (i < n)
	{
		printf("输入第%d个数：\n", i + 1);
		scanf("%d", &arr[i]);
		i++;
	}


	int max = arr[0];//最大值
	int min = arr[0];//最小值

	for (int t = 0; t < n; t++)
	{
		if (arr[t] > max)
			max = arr[t];
		if (arr[t] < min)
			min = arr[t];
	}
	printf("最大值为%d,\n最小值为%d", max, min);

	return 0;
}
